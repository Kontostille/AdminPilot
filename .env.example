# ==============================================================================
# AdminPilot - Environment Variables
# ==============================================================================
# Kopiere diese Datei nach `.env.local` und fülle die Werte aus.
# NIEMALS `.env.local` ins Git einchecken!
# ==============================================================================

# --- Frontend (Vite) ---
# Clerk Publishable Key: https://dashboard.clerk.com/ -> API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase (AdminPilot Projekt in Frankfurt-Region)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Edge Functions Endpoint (typisch: <SUPABASE_URL>/functions/v1)
VITE_SUPABASE_FUNCTIONS_URL=https://<project-ref>.supabase.co/functions/v1

# --- Supabase Edge Functions (server-side secrets, via `supabase secrets set`) ---
# Diese Variablen werden NICHT im Frontend verwendet, sondern in den Edge
# Functions per `Deno.env.get(...)`. Setzen mit:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...                       (NIE öffentlich!)
# ANTHROPIC_API_KEY=sk-ant-...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# APP_URL=https://adminpilot.de

# --- Clerk Webhook ---
# Für User-Sync: Clerk ruft einen Supabase Edge Function auf bei Sign-up.
# Endpoint URL in Clerk Dashboard:
#   https://<project-ref>.supabase.co/functions/v1/clerk-user-sync
# CLERK_WEBHOOK_SECRET=whsec_...
